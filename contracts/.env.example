# ============================================
# Aqua0 Contracts — Environment Variables
# ============================================
# Copy to .env and fill in values:
#   cp .env.example .env

# ── Deployer ────────────────────────────────
# Private key for the deployer account (no 0x prefix)
DEPLOYER_PRIVATE_KEY=

# ── RPC Endpoints ───────────────────────────
BASE_RPC_URL=https://mainnet.base.org
UNICHAIN_RPC_URL=https://mainnet.unichain.org

# ── Block Explorer API Key (for verification) ──
ETHERSCAN_API_KEY=

# ── Factory Version ────────────────────────
# Bump to redeploy AccountFactory on a chain where a previous version exists.
# Default: v1
# FACTORY_VERSION=v1

# ── Local Development ───────────────────────
# ANVIL_PORT=8545
